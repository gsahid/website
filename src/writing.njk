---
layout: base
permalink: /writing/
eleventyNavigation:
  key: Writing
  order: 3
---

<div class="container">
    <h1>Writing</h1>
    <p>Short updates about side projects and other things I'm working on.</p>
    
    {% set writinglist = collections.writing | reverse %}
    {% if writinglist.length %}
        <ul class="writing-list">
        {% for post in writinglist %}
            <li class="writing-item">
                <time class="writing-date">{{ post.date | readableDate }}</time>
                <h3 class="writing-title">
                    <a href="{{ post.url }}">{{ post.data.title }}</a>
                </h3>
                {% if post.data.excerpt %}
                    <p class="writing-excerpt">{{ post.data.excerpt }}</p>
                {% endif %}
            </li>
        {% endfor %}
        </ul>
    {% else %}
        <p>No posts yet.</p>
    {% endif %}
</div>